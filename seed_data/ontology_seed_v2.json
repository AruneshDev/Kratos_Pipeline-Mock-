{
  "nodes": [
    {
      "node_id": "SYS-LEGACY-DEPOSIT",
      "node_type": "System",
      "label": "Legacy Deposit System",
      "description": "COBOL/Java mainframe deposit insurance calculation system. Runs nightly batch jobs for ORC assignment and insurance calculation.",
      "system": "legacy_deposit",
      "properties": {"platform": "COBOL+Java", "job_scheduler": "JCL", "db": "DB2"}
    },
    {
      "node_id": "SYS-TRUST-CUSTODY",
      "node_type": "System",
      "label": "Trust & Custody System",
      "description": "Trust account management system. Handles IRR/REV/EBP/CUS/UTMA trust types and beneficiary tracking.",
      "system": "trust_custody",
      "properties": {"platform": "COBOL+Java", "job_scheduler": "JCL"}
    },
    {
      "node_id": "SYS-WIRE-TRANSFER",
      "node_type": "System",
      "label": "Wire Transfer System",
      "description": "SWIFT MT103/MT202 and ACH wire processing. Handles OFAC screening and settlement routing.",
      "system": "wire_transfer",
      "properties": {"platform": "Java+Python", "protocols": ["SWIFT", "ACH", "FedWire"]}
    },
    {
      "node_id": "SYS-PIPELINE-API",
      "node_type": "System",
      "label": "Bank Pipeline API",
      "description": "Containerized FastAPI orchestration service. Triggers nightly pipeline runs and exposes control evaluation and RCA context.",
      "system": "pipeline_api",
      "properties": {"platform": "FastAPI/Python", "port": 8080}
    },
    {
      "node_id": "JOB-DAILY-DEPOSIT",
      "node_type": "Job",
      "label": "DAILY-INSURANCE-JOB",
      "description": "Nightly JCL batch job for deposit insurance. Runs ORC assignment, aggregation, and SMDIA calculation steps.",
      "system": "legacy_deposit",
      "properties": {"schedule": "nightly", "jcl_file": "DAILY-INSURANCE-JOB.jcl"}
    },
    {
      "node_id": "JOB-DAILY-TRUST",
      "node_type": "Job",
      "label": "DAILY-TRUST-JOB",
      "description": "Nightly JCL batch job for trust insurance. Runs trust ORC assignment, beneficiary counting, and IRR coverage calculation.",
      "system": "trust_custody",
      "properties": {"schedule": "nightly", "jcl_file": "DAILY-TRUST-JOB.jcl"}
    },
    {
      "node_id": "JOB-WIRE-SETTLEMENT",
      "node_type": "Job",
      "label": "Wire Daily Settlement Job",
      "description": "Daily wire settlement batch. Processes SWIFT/ACH wires, runs OFAC screening, reconciliation, and coverage check.",
      "system": "wire_transfer",
      "properties": {"schedule": "daily", "scripts": ["process_daily_wires.sh", "acb_batch_settlement.sh"]}
    },
    {
      "node_id": "JOB-NIGHTLY-PIPELINE-RUN",
      "node_type": "Job",
      "label": "Nightly Bank Pipeline Run",
      "description": "Orchestrated pipeline job invoked by the Pipeline API. Executes all 14 stage pipelines across all 3 banking systems.",
      "system": "pipeline_api",
      "properties": {"triggered_by": "POST /runs", "stages": 14}
    },
    {
      "node_id": "PL-DEPOSIT-ORC-ASSIGN",
      "node_type": "Pipeline",
      "label": "Deposit ORC Assignment Pipeline",
      "description": "Assigns ORC codes (SGL/JNT/GOV/EBP/IRR/REV) to all deposit accounts. Missing IRR branch causes silent SGL fallthrough.",
      "system": "legacy_deposit",
      "properties": {"stage": "orc_assign", "entry_script": "DEPOSIT-INSURANCE-CALC.cob"}
    },
    {
      "node_id": "PL-DEPOSIT-INSURANCE-CALC",
      "node_type": "Pipeline",
      "label": "Deposit Insurance Calculation Pipeline",
      "description": "Applies SMDIA per depositor per ORC. Currently calculates per-account instead of per-depositor aggregate.",
      "system": "legacy_deposit",
      "properties": {"stage": "insurance", "stored_proc": "sp_calculate_insurance.sql"}
    },
    {
      "node_id": "PL-TRUST-ORC-ASSIGN",
      "node_type": "Pipeline",
      "label": "Trust ORC Assignment Pipeline",
      "description": "Assigns ORC codes to trust accounts. TRUST-INSURANCE-CALC.cob has no WHEN 'IRR' branch, causing misclassification.",
      "system": "trust_custody",
      "properties": {"stage": "orc_assign", "entry_script": "ORC-ASSIGNMENT.cob"}
    },
    {
      "node_id": "PL-TRUST-INSURANCE-CALC",
      "node_type": "Pipeline",
      "label": "Trust Insurance Calculation Pipeline",
      "description": "Calculates coverage for trust accounts per 12 CFR 330.13. Requires per-beneficiary-interest calculation for IRR trusts.",
      "system": "trust_custody",
      "properties": {"stage": "insurance", "cobol_program": "TRUST-INSURANCE-CALC.cob"}
    },
    {
      "node_id": "PL-WIRE-SCREENING",
      "node_type": "Pipeline",
      "label": "Wire OFAC Screening Pipeline",
      "description": "Screens wire transactions against OFAC SDN list. Settled wires passing without screening is a critical compliance gap.",
      "system": "wire_transfer",
      "properties": {"stage": "screening", "script": "ofac_screening.py"}
    },
    {
      "node_id": "PL-WIRE-RECONCILIATION",
      "node_type": "Pipeline",
      "label": "Wire Reconciliation Pipeline",
      "description": "Reconciles wire transaction counts and amounts across pipeline stages.",
      "system": "wire_transfer",
      "properties": {"stage": "reconciliation", "script": "reconciliation.py"}
    },
    {
      "node_id": "PL-DEPOSIT-AGGREGATION",
      "node_type": "Pipeline",
      "label": "Deposit Aggregation Pipeline",
      "description": "Aggregates balances by depositor and ORC code before insurance calculation.",
      "system": "legacy_deposit",
      "properties": {"stage": "aggregation", "stored_proc": "sp_aggregate_deposits.sql"}
    },
    {
      "node_id": "SCR-ORC-ASSIGNMENT",
      "node_type": "Script",
      "label": "ORC-ASSIGNMENT.cob",
      "description": "COBOL program that evaluates trust type and assigns ORC code. Missing WHEN 'IRR' branch causes IRR trusts to receive SGL classification.",
      "system": "trust_custody",
      "properties": {"language": "COBOL", "path": "cobol/ORC-ASSIGNMENT.cob", "known_issue": "No WHEN 'IRR' branch in EVALUATE ORC-TYPE"}
    },
    {
      "node_id": "SCR-TRUST-INSURANCE-CALC",
      "node_type": "Script",
      "label": "TRUST-INSURANCE-CALC.cob",
      "description": "COBOL program computing insurance coverage for trust accounts. Does not implement per-beneficiary-interest logic for IRR type.",
      "system": "trust_custody",
      "properties": {"language": "COBOL", "path": "cobol/TRUST-INSURANCE-CALC.cob"}
    },
    {
      "node_id": "SCR-DEPOSIT-INSURANCE-CALC",
      "node_type": "Script",
      "label": "DEPOSIT-INSURANCE-CALC.cob",
      "description": "COBOL program applying SMDIA per account rather than per depositor aggregate. Violates 12 CFR 330.6.",
      "system": "legacy_deposit",
      "properties": {"language": "COBOL", "path": "cobol/DEPOSIT-INSURANCE-CALC.cob"}
    },
    {
      "node_id": "SCR-SP-CALC-INSURANCE",
      "node_type": "Script",
      "label": "sp_calculate_insurance.sql",
      "description": "SQL stored procedure for insurance calculation. Hardcodes SMDIA value and calculates per-account not per-depositor.",
      "system": "legacy_deposit",
      "properties": {"language": "SQL", "path": "sql/sp_calculate_insurance.sql", "known_issue": "DECLARE @SMDIA = 250000 hardcoded"}
    },
    {
      "node_id": "SCR-OFAC-SCREENING",
      "node_type": "Script",
      "label": "ofac_screening.py",
      "description": "Python OFAC screening module. Wires settle before screening completes when batch coordination fails.",
      "system": "wire_transfer",
      "properties": {"language": "Python", "path": "python/ofac_screening.py"}
    },
    {
      "node_id": "SCR-ORC-CLASSIFIER",
      "node_type": "Script",
      "label": "OrcClassifier.java",
      "description": "Java ORC classification service for deposit accounts. Delegates trust ORC to COBOL subroutine.",
      "system": "legacy_deposit",
      "properties": {"language": "Java", "path": "java/OrcClassifier.java"}
    },
    {
      "node_id": "TRN-ORC-CLASSIFICATION",
      "node_type": "Transformation",
      "label": "ORC Code Classification",
      "description": "Evaluates account/trust attributes and assigns the appropriate ORC category. Fails when trust_type=IRR has no matching branch.",
      "system": "trust_custody",
      "properties": {"logic": "EVALUATE ORC-TYPE WHEN 'SGL' ... WHEN 'IRR' [MISSING]"}
    },
    {
      "node_id": "TRN-INSURANCE-CALCULATION",
      "node_type": "Transformation",
      "label": "Insurance Amount Calculation",
      "description": "Applies SMDIA cap to depositor balances per ORC. Should aggregate per-depositor but currently runs per-account.",
      "system": "legacy_deposit",
      "properties": {"logic": "MIN(balance + accrued_interest, SMDIA)", "defect": "no GROUP BY depositor_id"}
    },
    {
      "node_id": "TRN-BENEFICIARY-INTEREST-CALC",
      "node_type": "Transformation",
      "label": "Beneficiary Interest Calculation",
      "description": "Computes per-beneficiary-interest for IRR trusts under 12 CFR 330.13. Currently unimplemented; IRR falls through to SGL flat-cap logic.",
      "system": "trust_custody",
      "properties": {"regulation": "12 CFR 330.13", "status": "NOT_IMPLEMENTED"}
    },
    {
      "node_id": "TRN-OFAC-SCREENING-CHECK",
      "node_type": "Transformation",
      "label": "OFAC SDN Screening",
      "description": "Validates wire counterparties against OFAC SDN list before settlement. Should block settlement until CLEARED status.",
      "system": "wire_transfer",
      "properties": {"required_status": "CLEARED", "violation": "SETTLED wires with NOT_SCREENED status present"}
    },
    {
      "node_id": "TRN-DEPOSIT-AGGREGATION",
      "node_type": "Transformation",
      "label": "Depositor Balance Aggregation",
      "description": "Groups balances by depositor_id and orc_code before applying SMDIA. Required by 12 CFR 330.6.",
      "system": "legacy_deposit",
      "properties": {"sql": "GROUP BY depositor_id, orc_type"}
    },
    {
      "node_id": "EVT-ORC-ASSIGN-LAST-CHANGE",
      "node_type": "CodeEvent",
      "label": "Last Change to ORC-ASSIGNMENT.cob",
